+# ---------------------------------------------------------------------
+# Silencing
+# ---------------------------------------------------------------------
+
+def _cycle_with_sink():
+    """A 3-cycle 0 -> 1 -> 2 -> 0 plus a sink node 3 fed by node 2.
+
+    adjacency[i, j] is the weight from j to i, so node 3's column is
+    all-zero: it has no outgoing edges.  The 3-cycle keeps the largest
+    real eigenvalue positive (it is 1), so _normalize_W takes its
+    rescaling branch as it would on a real connectome.
+    """
+    adj = np.zeros((4, 4))
+    adj[1, 0] = adj[2, 1] = adj[0, 2] = 1.0   # 3-cycle
+    adj[3, 2] = 1.0                           # 2 -> 3, node 3 is a sink
+    return adj
+
+
+def test_silencing_output_free_neuron_matches_no_silencing():
+    """Silencing a neuron that has no outgoing edges zeroes an
+    already-zero column, leaving W bit-for-bit unchanged -- so the
+    influence scores must match the unsilenced solve exactly.
+
+    This pins down the step that both branches of calculate_influence
+    must share: _normalize_W, which rescales W to lambda_max and then
+    subtracts the identity.  If the silenced branch ever skipped it and
+    solved W r = -s instead of (alpha * W - I) r = -s, these two results
+    would diverge by orders of magnitude even though W is identical.
+    """
+    _require_petsc_slepc()
+    ic = InfluenceCalculator.from_numpy(_cycle_with_sink(), count_thresh=0,
+                                        lambda_max=0.5)
+
+    col = 'Influence_score_(unsigned)'
+    base = ic.calculate_influence([0], adjust=False).sort_values('id')
+    sil = ic.calculate_influence([0], silenced_neurons=[3],
+                                 adjust=False).sort_values('id')
+
+    np.testing.assert_allclose(base[col].to_numpy(), sil[col].to_numpy(),
+                               rtol=1e-6, atol=1e-12)
+
+
+def test_silencing_blocks_downstream_propagation():
+    """Node 3 is reachable from seed 0 only through node 2, so silencing
+    node 2 must strip node 3 of essentially all of its influence.
+    """
+    _require_petsc_slepc()
+    ic = InfluenceCalculator.from_numpy(_cycle_with_sink(), count_thresh=0,
+                                        lambda_max=0.5)
+    col = 'Influence_score_(unsigned)'
+
+    def score(df, node):
+        return df.loc[df['id'] == node, col].iloc[0]
+
+    base = ic.calculate_influence([0], adjust=False)
+    sil = ic.calculate_influence([0], silenced_neurons=[2], adjust=False)
+
+    assert score(base, 3) > 0
+    assert score(sil, 3) < score(base, 3)
+    assert score(sil, 3) == pytest.approx(0.0, abs=1e-12)
+
+
+def test_silencing_only_seeds_is_a_no_op(celegans_edgelist_df,
+                                         celegans_meta_df):
+    """calculate_influence drops seed neurons from the silenced set, so
+    asking to silence nothing but the seeds must leave the result
+    identical to not silencing at all.
+    """
+    _require_petsc_slepc()
+    ic = InfluenceCalculator(celegans_edgelist_df, celegans_meta_df,
+                             count_thresh=0, lambda_max=0.5)
+    seeds = ['ADAL', 'ADAR']
+    col = 'Influence_score_(unsigned)'
+
+    base = ic.calculate_influence(seeds, adjust=False).sort_values('id')
+    sil = ic.calculate_influence(seeds, silenced_neurons=seeds,
+                                 adjust=False).sort_values('id')
+
+    np.testing.assert_allclose(base[col].to_numpy(), sil[col].to_numpy(),
+                               rtol=1e-6, atol=1e-12)
+    assert sil['is_seed'].sum() == len(seeds)
+
+
+def test_silencing_changes_influence_on_real_connectome(celegans_edgelist_df,
+                                                        celegans_meta_df):
+    """Silencing a genuinely connected population must move the scores,
+    and must leave them finite and on the same scale (which is what the
+    shared _normalize_W guarantees).
+    """
+    _require_petsc_slepc()
+    ic = InfluenceCalculator(celegans_edgelist_df, celegans_meta_df,
+                             count_thresh=0, lambda_max=0.5)
+    seeds = ['ADAL', 'ADAR']
+    col = 'Influence_score_(unsigned)'
+
+    hubs = [n for n in ('AVAL', 'AVAR', 'AVBL', 'AVBR')
+            if n in ic.id_to_index]
+    assert hubs, 'expected command interneurons in the bundled connectome'
+
+    base = ic.calculate_influence(seeds, adjust=False).sort_values('id')
+    sil = ic.calculate_influence(seeds, silenced_neurons=hubs,
+                                 adjust=False).sort_values('id')
+
+    assert np.all(np.isfinite(sil[col].to_numpy()))
+    assert not np.allclose(base[col].to_numpy(), sil[col].to_numpy())
+
+
+def test_feedforward_W_warns_and_does_not_blow_up():
+    """A purely feedforward W is nilpotent: its true leading eigenvalue is
+    exactly 0, so there is nothing to rescale against and lambda_max
+    cannot take effect.
+
+    SLEPc does not return 0 here.  A nilpotent matrix is defective, and
+    eigenvalues of defective matrices carry error on the order of
+    eps**(1/m), so SLEPc converges to a small *positive* value (~3.7e-5
+    for this chain).  A bare `> 0` guard accepts that noise as a genuine
+    eigenvalue, alpha = lambda_max / 3.7e-5 inflates W by ~1.4e4, and the
+    influence scores come back around 1e12 -- silently, with no NaN and
+    no error.  The relative floor in _normalize_W exists to catch exactly
+    this, so assert both halves: the warning fires, and the scores stay
+    on the O(1) scale the Neumann sum actually implies.
+    """
+    _require_petsc_slepc()
+    adj = np.zeros((4, 4))
+    adj[1, 0] = adj[2, 1] = adj[3, 2] = 1.0   # chain, no cycle -> nilpotent
+    ic = InfluenceCalculator.from_numpy(adj, count_thresh=0, lambda_max=0.5)
+
+    with pytest.warns(RuntimeWarning, match='lambda_max'):
+        df = ic.calculate_influence([0], adjust=False)
+
+    scores = df['Influence_score_(unsigned)'].to_numpy()
+    assert np.all(np.isfinite(scores))
+    # unrescaled chain: seed at 1, each hop passes the signal through at
+    # unit weight, so every node settles at 1 -- nowhere near 1e12.
+    np.testing.assert_allclose(np.sort(scores), np.ones(4), rtol=1e-6)
+
+
