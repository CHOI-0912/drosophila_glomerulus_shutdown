+    # Smallest largest-real-eigenvalue, as a fraction of ||W||_F, that is
+    # treated as a real recurrent mode rather than numerical noise from a
+    # (near-)nilpotent W.  See _normalize_W for why a bare `> 0` test is
+    # not enough.
+    _EIG_REL_FLOOR = 1e-3
